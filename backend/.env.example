# --- DATABASE ---
DATABASE_URL=sqlite:///./medizen.db

# --- JWT ---
SECRET_KEY=yoursecretkey
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- SMTP / EMAIL NOTIFICATIONS ---
# Omitir o usar "localhost-mock" para que los correos se impriman en consola (entorno de pruebas local)
SMTP_HOST=localhost-mock
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ADMIN_EMAIL=admin@medizen.cl
DEFAULT_FROM_EMAIL=no-reply@medizen.cl
