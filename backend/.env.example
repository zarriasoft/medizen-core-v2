# --- DATABASE ---
# SQLite local (desarrollo): sqlite:///./medizen_core.db
# PostgreSQL (produccion): postgresql://usuario:password@host:5432/dbname
DATABASE_URL=sqlite:///./medizen_core.db

# --- JWT ---
SECRET_KEY=genera-una-clave-segura-aqui
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- SMTP / EMAIL ---
# Usar "localhost-mock" para pruebas locales (imprime correos en consola)
SMTP_HOST=localhost-mock
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ADMIN_EMAIL=admin@medizen.cl
DEFAULT_FROM_EMAIL=no-reply@medizen.cl

# --- CORS ---
# Origenes permitidos separados por coma
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
