# =========================================
# MediZen Core - Portal Administrativo
# Configuracion de variables de entorno
# =========================================
#
# INSTRUCCIONES:
# 1. Copia este archivo a .env:  copy .env.example .env
# 2. Reemplaza los valores placeholder con tus claves reales
# 3. NUNCA comitees el archivo .env (esta en .gitignore)
#
# Para produccion, configura estas variables en:
# Vercel Dashboard > Settings > Environment Variables

# Clave API de Google Gemini (requerida para IA - MTC)
# Obtener en: https://aistudio.google.com/apikey
GEMINI_API_KEY=tu_api_key_aqui

# URL del backend (API)
# Desarrollo local: http://localhost:8000
# Produccion: https://medizen-api.onrender.com
VITE_API_URL=http://localhost:8000

# URL donde se despliega este frontend
APP_URL=http://localhost:5173
