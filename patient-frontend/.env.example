# =========================================
# MediZen Core - Portal de Pacientes
# Configuracion de variables de entorno
# =========================================
#
# INSTRUCCIONES:
# 1. Copia este archivo a .env:  copy .env.example .env
# 2. Reemplaza los valores placeholder con tus claves reales
# 3. NUNCA comitees el archivo .env (esta en .gitignore)
#
# Para produccion, configura estas variables en:
# Vercel Dashboard > Settings > Environment Variables

# URL del backend (API REST)
VITE_API_URL=http://localhost:8000

# URL del backend (WebSocket)
VITE_WS_URL=ws://localhost:8000
